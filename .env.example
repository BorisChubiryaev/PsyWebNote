# Скопируйте этот файл как .env и заполните значения
# cp .env.example .env

# ── Frontend ──
VITE_MISTRAL_API_KEY=ваш_ключ_mistral_ai

# Backend API URL (оставьте пустым для работы без бэкенда)
# VITE_API_URL=http://localhost:3001/api
# VITE_API_URL=/api  # для Vercel

# ── Backend ──
JWT_SECRET=сгенерируйте-случайную-строку-32-символа
JWT_REFRESH_SECRET=другая-случайная-строка-32-символа
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173
